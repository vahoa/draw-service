# ============================================
# 抽奖服务 - 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改
# ============================================

# ============================================
# Nacos配置
# ============================================
NACOS_SERVER_ADDR=nacos:8848
NACOS_NAMESPACE=prod
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ============================================
# 数据库配置
# ============================================
MYSQL_URL=jdbc:mysql://mysql:3306/lottery?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password

# ============================================
# Redis配置
# ============================================
REDIS_CLUSTER_NODES=redis1:7000,redis2:7001,redis3:7002,redis4:7003,redis5:7004,redis6:7005
REDIS_PASSWORD=your_redis_password
REDISSON_ADDRESS=redis://redis1:7000

# ============================================
# Kafka配置
# ============================================
KAFKA_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092

# ============================================
# MongoDB配置
# ============================================
MONGODB_URI=mongodb://mongodb:27017/lottery

# ============================================
# Sentinel配置
# ============================================
SENTINEL_DASHBOARD=sentinel-dashboard:8080

# ============================================
# 区域配置
# ============================================
REGION=cn-north-1
